# Actero — environment variables template
# Copy to `.env` (local dev) or set in Vercel dashboard (prod/preview).
# Do NOT commit actual secrets — this file shows shape, not values.

# ─── Supabase ──────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# ─── Amplitude Analytics ───────────────────────────────────────────────
# Client SDK (browser). Exposed to the bundle — safe by design (public key).
# Falls back to the hardcoded production key if unset (see src/lib/analytics.ts).
VITE_AMPLITUDE_API_KEY=19e42a5d2488202ad9d13fa8b5d6545
# Server-side SDK key — same workspace, used by api/lib/amplitude.js for
# server-originated events (Ticket Resolved / Escalated fired from the engine).
# Can be identical to the client key, Amplitude doesn't distinguish.
AMPLITUDE_API_KEY=19e42a5d2488202ad9d13fa8b5d6545

# ─── Sentry ────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=
# Backend DSN for @sentry/node (Vercel Serverless Functions). Loaded at cold
# start via instrument.mjs. Leave empty in dev to skip reporting.
SENTRY_DSN=
# Source map upload + release tracking via @sentry/vite-plugin. Only used at
# build time in CI/Vercel — leave empty locally to skip upload.
# Create at https://sentry.io/settings/account/api/auth-tokens/ with scope
# `project:releases` + `project:write`. Set SENTRY_ORG and SENTRY_PROJECT to
# your Sentry slugs (default: actero / javascript-react).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=actero
SENTRY_PROJECT=javascript-react

# ─── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Vercel ────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ─── Shopify ───────────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# ─── OpenAI / LLM ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Slack notifications (signup ping) ─────────────────────────────────
SLACK_WEBHOOK_URL=

{
    "redirects": [
        { "source": "/pricing", "destination": "/tarifs", "permanent": true },
        { "source": "/company", "destination": "/entreprise", "permanent": true },
        { "source": "/about", "destination": "/entreprise", "permanent": true },
        { "source": "/legal", "destination": "/mentions-legales", "permanent": true },
        { "source": "/privacy", "destination": "/confidentialite", "permanent": true },
        { "source": "/privacy-policy", "destination": "/confidentialite", "permanent": true },
        { "source": "/terms", "destination": "/utilisation", "permanent": true },
        { "source": "/terms-of-use", "destination": "/utilisation", "permanent": true },
        { "source": "/cgu", "destination": "/utilisation", "permanent": true },
        { "source": "/resources", "destination": "/ressources", "permanent": true },
        { "source": "/help", "destination": "/support", "permanent": true },
        { "source": "/contact", "destination": "/support", "permanent": true },

        { "source": "/alternative-gorgias/", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/alternative-tidio/", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/alternative-zendesk/", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/Alternative-Gorgias", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/Alternative-Tidio", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/Alternative-Zendesk", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/gorgias-alternative", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/tidio-alternative", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/zendesk-alternative", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/alternatives-gorgias", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/alternatives-tidio", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/alternatives-zendesk", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/gorgias-vs-actero", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/tidio-vs-actero", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/zendesk-vs-actero", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/vs/gorgias", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/vs/tidio", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/vs/zendesk", "destination": "/alternative-zendesk", "permanent": true },

        { "source": "/comparaison/gorgias", "destination": "/alternative-gorgias", "permanent": true },
        { "source": "/comparaison/tidio", "destination": "/alternative-tidio", "permanent": true },
        { "source": "/comparaison/zendesk", "destination": "/alternative-zendesk", "permanent": true }
    ],
    "rewrites": [
        {
            "source": "/api/mcp/.well-known/oauth-authorization-server",
            "destination": "/api/mcp/oauth-metadata"
        },
        {
            "source": "/api/mcp/.well-known/oauth-protected-resource",
            "destination": "/api/mcp/oauth-resource"
        },
        {
            "source": "/.well-known/oauth-authorization-server",
            "destination": "/api/mcp/oauth-metadata"
        },
        {
            "source": "/.well-known/oauth-protected-resource",
            "destination": "/api/mcp/oauth-resource"
        },
        {
            "source": "/authorize",
            "destination": "/api/mcp/authorize"
        },
        {
            "source": "/token",
            "destination": "/api/mcp/token"
        },
        {
            "source": "/register",
            "destination": "/api/mcp/register"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/process-abandoned-carts",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/cron/process-comptabilite",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/monthly-report",
            "schedule": "0 8 1 * *"
        },
        {
            "path": "/api/cron/churn-predictions",
            "schedule": "0 6 * * 0"
        },
        {
            "path": "/api/cron/slack-daily-digest",
            "schedule": "30 7 * * 1-5"
        },
        {
            "path": "/api/cron/poll-inbound-emails",
            "schedule": "*/2 * * * *"
        },
        {
            "path": "/api/cron/proactive-watchdog",
            "schedule": "*/15 * * * *"
        }
    ],
    "headers": [
        {
            "source": "/widget.js",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Robots-Tag", "value": "index, follow" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=()" }
            ]
        }
    ]
}

{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/widget.js",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Robots-Tag", "value": "index, follow" }
            ]
        }
    ]
}

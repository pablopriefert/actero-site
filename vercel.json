{
    "rewrites": [
        {
            "source": "/api/mcp/.well-known/oauth-authorization-server",
            "destination": "/api/mcp/oauth-metadata"
        },
        {
            "source": "/api/mcp/.well-known/oauth-protected-resource",
            "destination": "/api/mcp/oauth-resource"
        },
        {
            "source": "/.well-known/oauth-authorization-server",
            "destination": "/api/mcp/oauth-metadata"
        },
        {
            "source": "/.well-known/oauth-protected-resource",
            "destination": "/api/mcp/oauth-resource"
        },
        {
            "source": "/authorize",
            "destination": "/api/mcp/authorize"
        },
        {
            "source": "/token",
            "destination": "/api/mcp/token"
        },
        {
            "source": "/register",
            "destination": "/api/mcp/register"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/process-abandoned-carts",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/cron/process-comptabilite",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/monthly-report",
            "schedule": "0 8 1 * *"
        },
        {
            "path": "/api/cron/churn-predictions",
            "schedule": "0 6 * * 0"
        }
    ],
    "headers": [
        {
            "source": "/widget.js",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
                { "key": "Pragma", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Robots-Tag", "value": "index, follow" }
            ]
        }
    ]
}
